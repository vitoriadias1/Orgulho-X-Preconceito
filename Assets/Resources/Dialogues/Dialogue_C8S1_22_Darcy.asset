  m_Script: {fileID: 11500000, guid: 67bcde90fc55e5546bc7c98868d3fe59, type: 3}
  m_Name: Dialogue_C8S1_22_Darcy
  m_EditorClassIdentifier: Assembly-CSharp::DialogueLine
  speaker: Darcy
  text: "E eu tornei f\xE1cil que me julgassem. Fui orgulhoso onde deveria ter sido
    gentil, fechado onde deveria ter sido honesto. Mas estar perto de voc\xEA...
    \xE9 o maior privil\xE9gio que poderia ter."
  portrait: {fileID: 0}
  voice: {fileID: 0}
  choices:
  - choiceText: "[CAN\xD4NICA] Talvez tenhamos aprendido igualmente. E talvez possamos
      aprender juntos daqui em diante."
    prideChange: -1
    prejudiceChange: -1
    relationshipChanges:
    - npcName: Darcy
      changeAmount: 1
  - choiceText: '[ERRADA] Acho que ainda preciso de tempo para confiar completamente.'
    prideChange: 0.2
    prejudiceChange: 0.2
    relationshipChanges:
    - npcName: Darcy
      changeAmount: -0.2
